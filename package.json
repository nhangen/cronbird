{
  "name": "cronbird",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./src/core/index.ts"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
